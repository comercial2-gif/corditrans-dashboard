(function init(){
  const sc=document.getElementById('f-cli');
  CLIENTES.forEach((c,i)=>{const o=document.createElement('option');o.value=i;o.textContent=c;sc.appendChild(o);});
  const so=document.getElementById('f-op');
  TIPO_OPS.forEach((o,i)=>{const opt=document.createElement('option');opt.value=i;opt.textContent=o;so.appendChild(opt);});
  const sf=document.getElementById('f-fl');
  TIPO_FLS.forEach((f,i)=>{const opt=document.createElement('option');opt.value=i;opt.textContent=f;sf.appendChild(opt);});
  const vc=document.getElementById('vf-cli');
  if(vc)CLI_NAL.forEach(c=>{const o=document.createElement('option');o.value=c;o.textContent=c;vc.appendChild(o);});
  render();
})();
</script>
</body>
</html>
