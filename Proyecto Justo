<style>
:root{
  --bg:#05101e;--surf:#0a1828;--card:#0e1f30;--bdr:#152238;
  --a1:#00d4aa;--a2:#ff6b4a;--a3:#7c6aff;--a4:#f5c842;--a5:#60a5fa;
  --good:#22d3a0;--crit:#ff4466;--sam:#a78bfa;--txt:#dae4f4;--mut:#435f7a;
  --r0:#00d4aa;--r1:#ff6b4a;--r2:#f5c842;--r3:#7c6aff;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);font-family:'DM Mono',monospace;color:var(--txt);min-height:100vh;overflow-x:hidden;}
/* LOADER BAR */
.loader-bar{padding:10px 28px;background:linear-gradient(135deg,#0a1828,#0d2040);border-bottom:2px solid rgba(0,212,170,.2);display:flex;gap:10px;align-items:center;flex-wrap:wrap;}
.lb-title{font-family:'Syne',sans-serif;font-weight:700;font-size:11px;color:var(--a1);white-space:nowrap;text-transform:uppercase;letter-spacing:.1em;}
.lb-sep{width:1px;height:22px;background:var(--bdr);flex-shrink:0;}
.lb-status{font-size:10px;padding:4px 11px;border-radius:10px;font-weight:600;white-space:nowrap;}
.lb-ok{background:rgba(0,212,170,.1);color:var(--a1);border:1px solid rgba(0,212,170,.25);}
.lb-warn{background:rgba(245,200,66,.08);color:var(--a4);border:1px solid rgba(245,200,66,.25);}
.lb-err{background:rgba(255,68,102,.08);color:var(--crit);border:1px solid rgba(255,68,102,.25);}
.lb-loading{background:rgba(96,165,250,.08);color:var(--a5);border:1px solid rgba(96,165,250,.25);}
.lb-input{background:var(--surf);border:1px solid rgba(0,212,170,.3);color:var(--a1);font-family:'DM Mono',monospace;font-size:11px;padding:6px 10px;border-radius:6px;outline:none;min-width:260px;flex:1;}
.lb-input::placeholder{color:var(--mut);}
.lb-btn{background:var(--a1);color:#05101e;font-family:'Syne',sans-serif;font-weight:700;font-size:11px;padding:7px 14px;border-radius:6px;border:none;cursor:pointer;text-transform:uppercase;letter-spacing:.08em;white-space:nowrap;}
.lb-btn:hover{opacity:.85;}
.lb-btn2{background:transparent;border:1px solid var(--bdr);color:var(--mut);font-family:'DM Mono',monospace;font-size:11px;padding:6px 12px;border-radius:6px;cursor:pointer;text-transform:uppercase;letter-spacing:.08em;white-space:nowrap;}
.lb-btn2:hover{border-color:var(--a5);color:var(--a5);}
.pb{width:100%;height:3px;background:var(--bdr);border-radius:2px;overflow:hidden;display:none;}
.pbf{height:100%;background:var(--a1);border-radius:2px;transition:width .3s;}
#drop-zone{position:fixed;inset:0;background:rgba(5,16,30,.93);z-index:9999;display:none;align-items:center;justify-content:center;}
#drop-zone.on{display:flex;}
.dz{border:2px dashed var(--a1);border-radius:16px;padding:50px 70px;text-align:center;}
.dz-ico{font-size:48px;margin-bottom:10px;}
.dz-t{font-family:'Syne',sans-serif;font-weight:700;font-size:16px;color:var(--a1);}
.dz-s{font-size:11px;color:var(--mut);margin-top:5px;}
/* HEADER */
header{padding:16px 28px 12px;background:linear-gradient(135deg,#05101e 45%,#0a1a35);border-bottom:1px solid var(--bdr);display:flex;align-items:flex-end;justify-content:space-between;gap:12px;flex-wrap:wrap;}
.logo h1{font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--a1);}
.logo p{font-size:10px;color:var(--mut);margin-top:2px;text-transform:uppercase;letter-spacing:.09em;}
.hchips{display:flex;gap:9px;flex-wrap:wrap;}
.chip{background:var(--card);border:1px solid var(--bdr);border-radius:7px;padding:6px 11px;font-size:9px;color:var(--mut);text-transform:uppercase;letter-spacing:.05em;}
.chip span{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;display:block;margin-bottom:1px;}
.xc1 span{color:var(--a1);}.xc2 span{color:var(--a4);}.xc3 span{color:var(--a2);}.xc4 span{color:var(--sam);}.xc5 span{color:var(--a5);}
/* GLOBAL FILTERS */
.gfilter{padding:10px 28px;background:linear-gradient(135deg,var(--card),#0c1b2e);border-bottom:2px solid rgba(96,165,250,.18);display:flex;gap:9px;flex-wrap:wrap;align-items:center;}
.gfl{font-size:10px;text-transform:uppercase;letter-spacing:.09em;white-space:nowrap;}
.gfl.fc{color:var(--a1);}.gfl.fm{color:var(--a5);}.gfl.fr{color:var(--a4);}.gfl.fo{color:var(--a2);}.gfl.ff{color:var(--sam);}
select,input[type=text]{background:var(--surf);border:1px solid var(--bdr);color:var(--txt);font-family:'DM Mono',monospace;font-size:12px;padding:6px 10px;border-radius:6px;outline:none;transition:border-color .15s;cursor:pointer;}
select:focus,input:focus{border-color:var(--a1);}
.sc{border-color:rgba(0,212,170,.3);color:var(--a1);}.sm{border-color:rgba(96,165,250,.3);color:var(--a5);}
.sr{border-color:rgba(245,200,66,.3);color:var(--a4);}.so{border-color:rgba(255,107,74,.3);color:var(--a2);}.sf{border-color:rgba(167,139,250,.3);color:var(--sam);}
.btn{background:transparent;border:1px solid var(--bdr);color:var(--mut);font-family:'DM Mono',monospace;font-size:11px;padding:6px 12px;border-radius:6px;cursor:pointer;text-transform:uppercase;letter-spacing:.08em;transition:all .14s;white-space:nowrap;}
.btn:hover{border-color:var(--a1);color:var(--a1);}
.finfo{font-size:9px;color:var(--a5);padding:3px 8px;background:rgba(96,165,250,.07);border-radius:10px;border:1px solid rgba(96,165,250,.18);}
/* TABS */
.tabs{display:flex;border-bottom:1px solid var(--bdr);background:var(--surf);padding:0 28px;overflow-x:auto;}
.tab{padding:11px 16px;font-size:11px;text-transform:uppercase;letter-spacing:.09em;color:var(--mut);cursor:pointer;border-bottom:2px solid transparent;transition:all .14s;user-select:none;white-space:nowrap;}
.tab:hover{color:var(--txt);}.tab.active{color:var(--a1);border-bottom-color:var(--a1);}
/* LAYOUT */
main{padding:16px 28px;}.page{display:none;}.page.active{display:block;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;}
.g3{display:grid;grid-template-columns:2fr 1fr;gap:12px;margin-bottom:12px;}
.g3l{display:grid;grid-template-columns:1fr 2fr;gap:12px;margin-bottom:12px;}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:11px;margin-bottom:12px;}
.g5{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:12px;}
.g6{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:12px;}
@media(max-width:900px){.g2,.g3,.g3l,.g4,.g5,.g6{grid-template-columns:1fr 1fr;}}
/* PANEL */
.panel{background:var(--card);border:1px solid var(--bdr);border-radius:11px;padding:15px;}
.ptit{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--mut);margin-bottom:11px;display:flex;align-items:center;gap:6px;}
.ptit::before{content:'';width:3px;height:11px;border-radius:2px;display:inline-block;flex-shrink:0;}
.pg .ptit::before{background:var(--a1);}.py .ptit::before{background:var(--a4);}.po .ptit::before{background:var(--a2);}
.pb2 .ptit::before{background:var(--a5);}.pp .ptit::before{background:var(--a3);}.pm .ptit::before{background:var(--sam);}
/* KPI */
.km{padding:12px;border-radius:10px;background:var(--card);border:1px solid var(--bdr);position:relative;overflow:hidden;}
.km::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.k1::before{background:var(--a1);}.k2::before{background:var(--a4);}.k3::before{background:var(--a2);}
.k4::before{background:var(--a5);}.k5::before{background:var(--sam);}
.kl{font-size:9px;text-transform:uppercase;letter-spacing:.12em;color:var(--mut);margin-bottom:4px;}
.kv{font-family:'Syne',sans-serif;font-weight:800;font-size:20px;line-height:1;}
.ks{font-size:9px;color:var(--mut);margin-top:3px;}
.k1 .kv{color:var(--a1);}.k2 .kv{color:var(--a4);}.k3 .kv{color:var(--a2);}.k4 .kv{color:var(--a5);}.k5 .kv{color:var(--sam);}
/* PIPELINE */
.pipe{background:var(--surf);border:1px solid var(--bdr);border-radius:11px;padding:12px 16px;margin-bottom:12px;display:flex;align-items:stretch;gap:0;flex-wrap:wrap;}
.ps{display:flex;align-items:center;gap:8px;flex:1;min-width:100px;}
.ps .ico{font-size:16px;flex-shrink:0;}
.ps .lbl{font-size:9px;text-transform:uppercase;letter-spacing:.1em;color:var(--mut);}
.ps .val{font-family:'Syne',sans-serif;font-weight:800;font-size:19px;line-height:1;margin-top:1px;}
.parr{font-size:15px;color:var(--bdr);padding:0 5px;flex-shrink:0;align-self:center;}
.pu{font-size:10px;color:var(--mut);font-weight:400;margin-left:1px;}
.p1 .val{color:var(--a1);}.p2 .val{color:var(--a4);}.p3 .val{color:var(--a2);}
.ptot{border:1px solid rgba(255,107,74,.25);border-radius:8px;padding:9px 12px;}.ptot .val{color:var(--a2);}
.ppag{border:1px solid rgba(96,165,250,.25);border-radius:8px;padding:9px 12px;}.ppag .val{color:var(--a5);}
.pmd{border:1px solid rgba(167,139,250,.25);border-radius:8px;padding:9px 12px;flex:0.6;}.pmd .val{color:var(--sam);}
/* BARS */
.bars{display:flex;flex-direction:column;gap:6px;}
.br{display:flex;align-items:center;gap:7px;}
.bn{font-size:10px;color:var(--mut);width:160px;min-width:90px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.bt{flex:1;height:6px;background:var(--bdr);border-radius:3px;overflow:hidden;}
.bf{height:100%;border-radius:3px;transition:width .45s cubic-bezier(.4,0,.2,1);}
.bv{font-size:10px;width:70px;text-align:right;flex-shrink:0;}
/* STACKED */
.sbar{display:flex;flex-direction:column;gap:8px;}
.srow{display:flex;flex-direction:column;gap:3px;}
.strack{display:flex;height:7px;border-radius:3px;overflow:hidden;gap:1px;}
.s0{background:var(--r0);height:100%;}.s1{background:var(--r1);height:100%;}.s2{background:var(--r2);height:100%;}.s3{background:var(--r3);height:100%;}
/* TABLE */
.tw{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:11px;}
thead th{text-align:left;padding:6px 8px;font-size:9px;text-transform:uppercase;letter-spacing:.12em;color:var(--mut);border-bottom:1px solid var(--bdr);white-space:nowrap;cursor:pointer;user-select:none;}
thead th:hover{color:var(--a1);}
tbody tr{border-bottom:1px solid rgba(255,255,255,.025);transition:background .1s;}
tbody tr:hover{background:rgba(255,255,255,.04);}
td{padding:6px 8px;vertical-align:middle;}
.bdg{display:inline-block;padding:2px 6px;border-radius:8px;font-size:10px;font-weight:500;min-width:40px;text-align:center;}
.b1{background:rgba(34,211,160,.12);color:var(--good);}.b2{background:rgba(245,200,66,.12);color:var(--a4);}
.b3{background:rgba(255,107,74,.12);color:var(--a2);}.b4{background:rgba(255,68,102,.12);color:var(--crit);}
.bn_{background:rgba(74,101,133,.1);color:var(--mut);}.bs{background:rgba(167,139,250,.12);color:var(--sam);}
.tag{display:inline-block;padding:1px 6px;border-radius:8px;font-size:9px;font-weight:600;}
.t-urb{background:rgba(0,212,170,.12);color:var(--a1);}.t-nal{background:rgba(245,200,66,.12);color:var(--a4);}
.t-prop{background:rgba(96,165,250,.12);color:var(--a5);}.t-terc{background:rgba(167,139,250,.12);color:var(--sam);}
/* SVG */
svg.trend{width:100%;}
.tick{font-size:9px;fill:#435f7a;font-family:'DM Mono',monospace;}
.tleg{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:9px;}
.li{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--mut);}
.ld{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
/* DIST */
.drow{display:flex;align-items:center;gap:7px;margin-bottom:6px;}
.dlbl{font-size:10px;color:var(--mut);width:68px;flex-shrink:0;}
.dtr{flex:1;height:15px;background:var(--bdr);border-radius:3px;overflow:hidden;}
.dfl{height:100%;display:flex;align-items:center;padding-left:5px;font-size:9px;font-weight:500;border-radius:3px;color:#05101e;transition:width .45s;}
/* VEH FILTER */
.vfbar{display:flex;gap:10px;flex-wrap:wrap;align-items:center;padding:10px 14px;background:var(--surf);border-radius:8px;border:1px solid var(--bdr);margin-bottom:13px;}
.vfl{font-size:10px;color:var(--sam);text-transform:uppercase;letter-spacing:.09em;white-space:nowrap;}
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--bdr);border-radius:3px;}
footer{margin:18px 28px 12px;padding-top:12px;border-top:1px solid var(--bdr);font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.08em;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;}
</style>
</head>
<body>

<!-- LOADER BAR -->
<div class="loader-bar">
  <div class="lb-title">📂 Fuente de datos</div>
  <div class="lb-sep"></div>
  <input id="gdrive-url" class="lb-input" type="text" placeholder="Pegar URL del Apps Script (termina en /exec)…">
  <button class="lb-btn" onclick="loadFromGDrive()">🔄 Actualizar desde Sheets</button>
  <div class="lb-sep"></div>
  <input type="file" id="file-input" accept=".xlsx,.xls" style="display:none" onchange="handleFile(this)">
