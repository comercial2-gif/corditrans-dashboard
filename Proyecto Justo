function processWB(buf){
  try{
    setProg(65);
    if(typeof XLSX==='undefined'){setSt('⚠ Librería XLSX no cargada. Verifique conexión a internet.','err');setProg(-1);return;}
    // cellDates:true → JS Date objects instead of serial numbers
    const wb=XLSX.read(buf,{type:'array',cellDates:true});
    const found=Object.keys(SHEETS_2026).filter(s=>wb.SheetNames.includes(s));
    if(!found.length){setSt('⚠ No se encontraron hojas de 2026','warn');setProg(-1);return;}
    const cli25=new Set(),pl25=new Set();
    SHEETS_2025.forEach(sh=>{
      if(!wb.SheetNames.includes(sh))return;
      parseSheet(wb.Sheets[sh]).forEach(r=>{if(r.CLIENTE)cli25.add(r.CLIENTE);if(r.PLACA)pl25.add(r.PLACA);});
    });
    setProg(75);
    let allRows=[],maxD='';
    found.forEach(sh=>{
      parseSheet(wb.Sheets[sh]).forEach(r=>{
        r._mes=SHEETS_2026[sh];
        const dc=r['FECHA DE CARG'];
        if(dc instanceof Date&&!isNaN(dc)){const s=dc.toISOString().slice(0,10);if(s>maxD)maxD=s;}
        allRows.push(r);
      });
    });
    if(!allRows.length){setSt('⚠ Sin registros válidos','warn');setProg(-1);return;}
    setProg(85);
    rebuildAll(allRows,cli25,pl25);
    setProg(-1);
    setSt(`✓ Actualizado · ${allRows.length.toLocaleString('es-CO')} viajes · hasta ${maxD}`,'ok');
    document.getElementById('footer-txt').textContent=`Datos actualizados · ${allRows.length.toLocaleString('es-CO')} registros · hasta ${maxD}`;
  }catch(err){console.error(err);setSt('✗ Error: '+err.message,'err');setProg(-1);}
}

function parseSheet(ws){
  // raw:true preserves JS Date objects from cellDates:true
  const raw=XLSX.utils.sheet_to_json(ws,{header:1,raw:true,defval:null});
  let hrow=-1;
  for(let i=0;i<Math.min(raw.length,15);i++){
    if(raw[i]&&String(raw[i][0]||'').trim().toUpperCase()==='CLIENTE'){hrow=i;break;}
  }
  if(hrow<0)return[];
  const hdrs=raw[hrow].map(h=>{
    const s=String(h||'').trim().toUpperCase();
    if(s.includes('TIPO')&&s.includes('OPER'))return'TIPO_OP';
    if(s.includes('TIPO')&&s.includes('FLOTA'))return'TIPO_FL';
    return s;
  });
  const rows=[];
  for(let i=hrow+1;i<raw.length;i++){
    const r=raw[i];if(!r)continue;
    const cli=String(r[0]||'').trim().toUpperCase();
    if(!cli||cli==='CLIENTE')continue;
    const obj={CLIENTE:cli};
    hdrs.forEach((h,j)=>{obj[h]=r[j]??null;});
    rows.push(obj);
  }
  return rows;
}

// Date parser — handles JS Date, Excel serial, ISO string, DD/MM/YYYY
function toD(v){
  if(!v||v===''||v==='nan'||v==='NaT')return null;
  if(v instanceof Date)return isNaN(v)?null:v;
  if(typeof v==='number'&&v>40000&&v<60000)return new Date(Math.round((v-25569)*86400000));
  if(typeof v==='string'){
    const s=v.trim();
    if(s.match(/^\d{4}-\d{2}-\d{2}/)){const d=new Date(s.slice(0,10));return isNaN(d)?null:d;}
    if(s.match(/^\d{2}\/\d{2}\/\d{4}$/)){const[dd,mm,yy]=s.split('/');const d=new Date(`${yy}-${mm}-${dd}`);return isNaN(d)?null:d;}
  }
  return null;
}
function dDiff(a,b){const da=toD(a),db=toD(b);if(!da||!db)return null;const d=Math.round((db-da)/86400000);return d>=-5&&d<=730?d:null;}
function toN(v){if(v===null||v===undefined)return 0;if(typeof v==='number')return isNaN(v)?0:v;const n=parseFloat(String(v).replace(/[^0-9.-]/g,''));return isNaN(n)?0:n;}

function rebuildAll(rows,cli25,pl25){
  const mesI={'2026-01':0,'2026-02':1,'2026-03':2,'2026-04':3,'2026-05':4};
  const rutI={'CTG-CTG':0,'CTG-NAL':1,'NAL-CTG':2,'NAL-NAL':3};
  function getR(r){const c=String(r['SITIO DE CARGUE']||'').toUpperCase().trim();const d=String(r['SITIO DESCARGUE']||'').toUpperCase().trim();if(c==='CARTAGENA'&&d==='CARTAGENA')return'CTG-CTG';if(c==='CARTAGENA')return'CTG-NAL';if(d==='CARTAGENA')return'NAL-CTG';return'NAL-NAL';}

  const cliArr=[...new Set(rows.map(r=>r.CLIENTE))].filter(Boolean).sort();
  const opArr=[...new Set(rows.map(r=>String(r.TIPO_OP||'?').toUpperCase().trim()))].sort();
  const flArr=[...new Set(rows.map(r=>String(r.TIPO_FL||'?').toUpperCase().trim()))].sort();
  const ciM={},oiM={},fiM={};
  cliArr.forEach((c,i)=>ciM[c]=i);opArr.forEach((o,i)=>oiM[o]=i);flArr.forEach((f,i)=>fiM[f]=i);

  const newREC=rows.map(r=>{
    const cli=ciM[r.CLIENTE]??0;const mes=mesI[r._mes]??0;const rut=rutI[getR(r)]??0;
    const op=oiM[String(r.TIPO_OP||'?').toUpperCase().trim()]??0;
    const fl=fiM[String(r.TIPO_FL||'?').toUpperCase().trim()]??0;
    return[cli,mes,rut,op,fl,
      Math.round(toN(r['V / F - FACTURAR'])),Math.round(toN(r['INTERMEDIACION'])),Math.round(toN(r['V / F - PAGAR'])),
      dDiff(r['FECHA DE CARG'],r['FECHA DE CUMPLIDO']),dDiff(r['FECHA DE CUMPLIDO'],r['FECHA FACTURA']),
      dDiff(r['FECHA FACTURA'],r['PAGO FACTURA']),dDiff(r['FECHA DE CARG'],r['FECHA FACTURA']),
      dDiff(r['FECHA DE CARG'],r['PAGO FACTURA']),
      (dDiff(r['FECHA DE CUMPLIDO'],r['FECHA FACTURA'])===0&&toD(r['FECHA FACTURA'])&&toD(r['FECHA DE CUMPLIDO']))?1:0
    ];
  });

  // Novedades
  // Clientes nuevos: aparecen en Abr o May pero NO en Ene-Feb-Mar
  const cliBase=new Set(rows.filter(r=>['2026-01','2026-02','2026-03'].includes(r._mes)).map(r=>r.CLIENTE));
  const cliNuevosMes={};
  ['2026-04','2026-05'].forEach(m=>{
    rows.filter(r=>r._mes===m).forEach(r=>{
      if(!cliBase.has(r.CLIENTE)&&!cliNuevosMes[r.CLIENTE]) cliNuevosMes[r.CLIENTE]=m;
    });
  });
  const newC=Object.keys(cliNuevosMes).map(c=>{
    const cr=rows.filter(r=>r.CLIENTE===c);const ops={},fls={};
    cr.forEach(r=>{const o=String(r.TIPO_OP||'?').toUpperCase();const f=String(r.TIPO_FL||'?').toUpperCase();ops[o]=(ops[o]||0)+1;fls[f]=(fls[f]||0)+1;});
    return{name:c,mes_inicio:cliNuevosMes[c]||'',viajes:cr.length,
      facturacion:cr.reduce((s,r)=>s+toN(r['V / F - FACTURAR']),0),
      intermediacion:cr.reduce((s,r)=>s+toN(r['INTERMEDIACION']),0),
      op:Object.entries(ops).sort((a,b)=>b[1]-a[1])[0]?.[0]||'?',
      fl:Object.entries(fls).sort((a,b)=>b[1]-a[1])[0]?.[0]||'?'};
  }).sort((a,b)=>b.facturacion-a.facturacion);

  const pR=rows.filter(r=>!toD(r['FECHA FACTURA']));
  const pM={};
  pR.forEach(r=>{const c=r.CLIENTE;if(!pM[c])pM[c]={name:c,count:0,value:0,meses:new Set()};pM[c].count++;pM[c].value+=toN(r['V / F - FACTURAR']);pM[c].meses.add(r._mes);});
  const pL=Object.values(pM).sort((a,b)=>b.count-a.count).map(p=>({...p,meses:[...p.meses].sort()}));

  // Vehículos nuevos: NACIONAL + TERCERIZADA únicamente (excluye PROPIA)
  const nalR=rows.filter(r=>String(r.TIPO_OP||'').toUpperCase().trim()==='NACIONAL'&&String(r.TIPO_FL||'').toUpperCase().trim()==='TERCERIZADA');
  const nalPl=new Set(nalR.map(r=>String(r.PLACA||'').toUpperCase().trim()).filter(Boolean));
  const newPl=[...nalPl].filter(p=>p&&!pl25.has(p));
  const vMap={};
  nalR.filter(r=>newPl.includes(String(r.PLACA||'').toUpperCase().trim())).forEach(r=>{
    const pl=String(r.PLACA||'').toUpperCase().trim();const key=pl+'|'+r._mes;
    if(!vMap[key])vMap[key]={placa:pl,mes:r._mes,primer_mes:'',viajes_mes:0,cliente:r.CLIENTE,tipo_fl:String(r.TIPO_FL||'?').toUpperCase().trim(),facturacion:0};
    vMap[key].viajes_mes++;vMap[key].facturacion+=toN(r['V / F - FACTURAR']);
  });
  const pmM={};Object.values(vMap).forEach(v=>{if(!pmM[v.placa]||v.mes<pmM[v.placa])pmM[v.placa]=v.mes;});
  const vD=Object.values(vMap).map(v=>({...v,primer_mes:pmM[v.placa]||v.mes,fidelizado:v.viajes_mes>=2}));
  const cliNal=[...new Set(nalR.map(r=>r.CLIENTE))].sort();

  // Update globals
  CLIENTES.length=0;cliArr.forEach(c=>CLIENTES.push(c));
  TIPO_OPS.length=0;opArr.forEach(o=>TIPO_OPS.push(o));
  TIPO_FLS.length=0;flArr.forEach(f=>TIPO_FLS.push(f));
  REC.length=0;newREC.forEach(r=>REC.push(r));
  NEW_CLIENTS.length=0;newC.forEach(c=>NEW_CLIENTS.push(c));
  PEND_CLI.length=0;pL.forEach(p=>PEND_CLI.push(p));
  window.PEND_TOTAL=pR.length;window.PEND_VALUE=pR.reduce((s,r)=>s+toN(r['V / F - FACTURAR']),0);
  VEH_DETAIL.length=0;vD.forEach(v=>VEH_DETAIL.push(v));
  CLI_NAL.length=0;cliNal.forEach(c=>CLI_NAL.push(c));

  function mAvg(a){const v=a.filter(x=>x!=null);return v.length?v.reduce((s,x)=>s+x,0)/v.length:0;}
  GLOB.total_viajes=newREC.length;GLOB.total_clientes=cliArr.length;
  GLOB.total_facturacion=newREC.reduce((s,r)=>s+r[5],0);
  GLOB.total_intermediacion=newREC.reduce((s,r)=>s+r[6],0);
  GLOB.total_pago=newREC.reduce((s,r)=>s+r[7],0);
  GLOB.avg_d1=+mAvg(newREC.map(r=>r[8])).toFixed(2);GLOB.avg_d2=+mAvg(newREC.map(r=>r[9])).toFixed(2);
  GLOB.avg_d3=+mAvg(newREC.map(r=>r[10])).toFixed(2);GLOB.avg_cf=+mAvg(newREC.map(r=>r[11])).toFixed(2);
  GLOB.avg_cp=+mAvg(newREC.map(r=>r[12])).toFixed(2);
  GLOB.mismo_dia=newREC.reduce((s,r)=>s+r[13],0);
  GLOB.con_factura=newREC.filter(r=>r[9]!=null).length;
  GLOB.con_pago=newREC.filter(r=>r[12]!=null).length;
  GLOB.pct_mismo_dia=GLOB.con_factura>0?+(GLOB.mismo_dia/GLOB.con_factura*100).toFixed(1):0;

  // Rebuild dropdowns
  [['f-cli',CLIENTES],['f-op',TIPO_OPS],['f-fl',TIPO_FLS]].forEach(([id,arr])=>{
    const el=document.getElementById(id);if(!el)return;
    const def=id==='f-cli'?'Todos los clientes':'Todas';
    el.innerHTML=`<option value="">${def}</option>`;
    arr.forEach((v,i)=>{const o=document.createElement('option');o.value=i;o.textContent=v;el.appendChild(o);});
  });
  const vc=document.getElementById('vf-cli');
  if(vc){vc.innerHTML='<option value="">Todos los clientes</option>';cliNal.forEach(c=>{const o=document.createElement('option');o.value=c;o.textContent=c;vc.appendChild(o);});}

  resetFilters();
}

