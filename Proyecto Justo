const SHEETS_2026={'ENERO 2026':'2026-01','FEBRERO 2026':'2026-02','MARZO2026':'2026-03','ABRIL 2026':'2026-04','MAYO2026':'2026-05'};
const SHEETS_2025=['ENERO 2025','FEBRERO 2025','MARZO2025','ABRIL 2025','MAYO 2025','JUNIO 2025','JULIO 2025','AGOSTO2025','SEPTIEMBRE 2025','OCTUBRE 2025','NOVIEMBRE 2025','DICIEMBRE 2025'];

function setSt(msg,t='ok'){const el=document.getElementById('lb-status');el.textContent=msg;el.className='lb-status lb-'+t;}
function setProg(p){const pb=document.getElementById('pb');const pf=document.getElementById('pbf');if(p>=0&&p<100){pb.style.display='block';pf.style.width=p+'%';}else pb.style.display='none';}

async function loadFromGDrive(){
  const raw=document.getElementById('gdrive-url').value.trim();
  if(!raw){setSt('⚠ Pega la URL del Apps Script','warn');return;}

  // Accepts both Apps Script /exec URL and regular Drive/Sheets links
  let url = raw;

  // If it's a regular Drive/Sheets link, warn user to use Apps Script URL
  if(raw.includes('drive.google.com') || raw.includes('docs.google.com/spreadsheets')){
    setSt('⚠ Use la URL de Apps Script (termina en /exec), no el enlace de Drive','warn');
    return;
  }

  setSt('⏳ Conectando con Google Sheets…','loading'); setProg(20);
  try{
    // Apps Script Web App returns JSON directly — no CORS issues
    const resp = await fetch(url);
    if(!resp.ok) throw new Error('HTTP ' + resp.status);
    setProg(50);
    const json = await resp.json();
    setProg(70);
    processGSheets(json);
  } catch(e) {
    setSt('✗ Error al conectar: ' + e.message + ' — verifique que el script esté publicado como "Cualquier persona"','err');
    setProg(-1);
    console.error(e);
  }
}

// Process data coming from Apps Script (array of arrays per sheet)
function processGSheets(data){
  try{
    const SHEETS_MAP = {
      'ENERO 2026':'2026-01','FEBRERO 2026':'2026-02','MARZO2026':'2026-03',
      'ABRIL 2026':'2026-04','MAYO2026':'2026-05',
      'ENERO 2025':'2025-01','FEBRERO 2025':'2025-02','MARZO2025':'2025-03',
      'ABRIL 2025':'2025-04','MAYO 2025':'2025-05','JUNIO 2025':'2025-06',
      'JULIO 2025':'2025-07','AGOSTO2025':'2025-08','SEPTIEMBRE 2025':'2025-09',
      'OCTUBRE 2025':'2025-10','NOVIEMBRE 2025':'2025-11','DICIEMBRE 2025':'2025-12'
    };

    const cli25  = new Set();
    const placas25 = new Set();
    let allRows  = [];
    let maxDateStr = '';

    Object.entries(data).forEach(([sheetName, rawRows]) => {
      const mes = SHEETS_MAP[sheetName];
      if(!mes) return;

      // Find header row (row where first cell = 'CLIENTE')
      let hrow = -1;
      for(let i=0;i<Math.min(rawRows.length,15);i++){
        if(String(rawRows[i][0]||'').trim().toUpperCase()==='CLIENTE'){hrow=i;break;}
      }
      if(hrow<0) return;

      const hdrs = rawRows[hrow].map(h=>{
        const s = String(h||'').trim().toUpperCase();
        if(s.includes('TIPO')&&s.includes('OPER')) return 'TIPO_OP';
        if(s.includes('TIPO')&&s.includes('FLOTA')) return 'TIPO_FL';
        return s;
      });

      for(let i=hrow+1;i<rawRows.length;i++){
        const r = rawRows[i];
        if(!r) continue;
        const cli = String(r[0]||'').trim().toUpperCase();
        if(!cli || cli==='CLIENTE') continue;
        const obj = {CLIENTE: cli, _mes: mes};
        hdrs.forEach((h,j)=>{ obj[h] = r[j]??null; });

        // Collect 2025 clients and plates for comparison
        if(mes.startsWith('2025')){
          cli25.add(cli);
          const pl = String(obj['PLACA']||'').trim().toUpperCase();
          if(pl) placas25.add(pl);
          return; // don't add 2025 to allRows
        }

        // Track max date
        const dc = toD(obj['FECHA DE CARG']);
        if(dc){ const s=dc.toISOString().slice(0,10); if(s>maxDateStr) maxDateStr=s; }

        allRows.push(obj);
      }
    });

    if(!allRows.length){
      setSt('⚠ No se encontraron registros de 2026 en el script','warn');
      setProg(-1); return;
    }

    setProg(85);
    rebuildAll(allRows, cli25, placas25);
    setProg(-1);
    setSt(`✓ Google Sheets · ${allRows.length.toLocaleString('es-CO')} viajes · hasta ${maxDateStr}`,'ok');
    document.getElementById('footer-txt').textContent =
      `Google Sheets · ${allRows.length.toLocaleString('es-CO')} registros · hasta ${maxDateStr}`;
  } catch(err){
    console.error(err);
    setSt('✗ Error procesando datos: '+err.message,'err');
    setProg(-1);
  }
}

