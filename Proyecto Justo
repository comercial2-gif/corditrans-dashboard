</div>
<div id="drop-zone"><div class="dz"><div class="dz-ico">📊</div><div class="dz-t">Soltar archivo aquí</div><div class="dz-s">CUADRO_DE_OPERACIONES_DIARIAS_2025_XX.xlsx</div></div></div>

<!-- HEADER -->
<header>
  <div class="logo">
    <h1>⬡ Control Operacional 2026 · Dashboard Integral</h1>
    <p>Facturación · Intermediación · Tiempos · Rutas · Operación · Flota · Novedades</p>
  </div>
  <div class="hchips">
    <div class="chip xc1"><span id="h-v">5,870</span>Viajes</div>
    <div class="chip xc2"><span id="h-f">$7.2 MM</span>Facturación</div>
    <div class="chip xc3"><span id="h-i">$1.28 MM</span>Intermediación</div>
    <div class="chip xc4"><span id="h-md">32.7%</span>Mismo día</div>
    <div class="chip xc5"><span id="h-cp">41.6 d</span>C→Pago</div>
  </div>
</header>

<!-- GLOBAL FILTERS -->
<div class="gfilter">
  <span class="gfl fc">👤 Cliente</span>
  <select id="f-cli" class="sc" onchange="applyFilters()"><option value="">Todos los clientes</option></select>
  <span class="gfl fm">🗓 Mes</span>
  <select id="f-mes" class="sm" onchange="applyFilters()">
    <option value="">Todos los meses</option>
    <option value="0">Enero 2026</option><option value="1">Febrero 2026</option>
    <option value="2">Marzo 2026</option><option value="3">Abril 2026</option><option value="4">Mayo 2026</option>
  </select>
  <span class="gfl fr">🗺️ Ruta</span>
  <select id="f-rut" class="sr" onchange="applyFilters()">
    <option value="">Todas las rutas</option>
    <option value="0">CTG → CTG</option><option value="1">CTG → Nacional</option>
    <option value="2">Nacional → CTG</option><option value="3">Nacional → Nacional</option>
