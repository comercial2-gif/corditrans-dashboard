<script>
// ══ INDICES ══
const CI=0,MI=1,RI=2,OI=3,FLI=4,FI=5,II=6,PI=7,D1=8,D2=9,D3=10,CF=11,CP=12,MDI=13;
const RC=['var(--r0)','var(--r1)','var(--r2)','var(--r3)'];
const RN=['CTG→CTG','CTG→Nal','Nal→CTG','Nal→Nal'];
const OC=['var(--a2)','var(--a1)'];
const FC_=['var(--a5)','var(--sam)'];
const ML={'2026-01':'Ene','2026-02':'Feb','2026-03':'Mar','2026-04':'Abr','2026-05':'May'};

// ══ HELPERS ══
const fm$=v=>v==null?'–':'$'+new Intl.NumberFormat('es-CO',{notation:'compact',maximumFractionDigits:1}).format(v);
const fd=v=>(v==null||isNaN(v))?'–':v.toFixed(1)+' d';
const fp=v=>v==null?'–':v.toFixed(1)+'%';
const fn=v=>v==null?'–':Math.round(v).toLocaleString('es-CO');
function avg(a){const v=a.filter(x=>x!=null);return v.length?v.reduce((s,x)=>s+x,0)/v.length:null;}
function zb(v,t){if(v==null)return'bn_';if(v<=t[0])return'b1';if(v<=t[1])return'b2';if(v<=t[2])return'b3';return'b4';}
function zc(v,t){const z=zb(v,t);return z==='b1'?'var(--good)':z==='b2'?'var(--a4)':z==='b3'?'var(--a2)':'var(--crit)';}

// ══ FILTER STATE ══
let FC='',FM='',FR='',FO='',FF='';
function applyFilters(){
  FC=document.getElementById('f-cli').value; FM=document.getElementById('f-mes').value;
  FR=document.getElementById('f-rut').value; FO=document.getElementById('f-op').value;
  FF=document.getElementById('f-fl').value;
  const fi=document.getElementById('finfo');
  const parts=[];
  if(FC!=='') parts.push(CLIENTES[+FC]);
  if(FM!=='') parts.push(MES_LABEL[MESES[+FM]]);
  if(FR!=='') parts.push(RN[+FR]);
  if(FO!=='') parts.push(TIPO_OPS[+FO]);
  if(FF!=='') parts.push(TIPO_FLS[+FF]);
  if(parts.length){fi.style.display='inline';fi.textContent='▸ '+parts.join(' · ');}
  else fi.style.display='none';
  render();
}
function resetFilters(){
  FC='';FM='';FR='';FO='';FF='';
  ['f-cli','f-mes','f-rut','f-op','f-fl'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('finfo').style.display='none';
  render();
}

// ══ DATA ACCESS ══
function rows(){
  return REC.filter(r=>{
    if(FC!==''&&r[CI]!==+FC)return false;
    if(FM!==''&&r[MI]!==+FM)return false;
    if(FR!==''&&r[RI]!==+FR)return false;
    if(FO!==''&&r[OI]!==+FO)return false;
    if(FF!==''&&r[FLI]!==+FF)return false;
    return true;
  });
}
function agg(recs){
  if(!recs.length)return{v:0,f:0,int:0,pag:0,d1:null,d2:null,d3:null,cf:null,cp:null,md:0,con_f:0,pct_md:0};
  const f=recs.reduce((s,r)=>s+r[FI],0);
  const int_=recs.reduce((s,r)=>s+r[II],0);
  const pag=recs.reduce((s,r)=>s+r[PI],0);
  const md=recs.reduce((s,r)=>s+r[MDI],0);
  const con_f=recs.filter(r=>r[D2]!=null).length;
  return{v:recs.length,f,int:int_,pag,d1:avg(recs.map(r=>r[D1])),d2:avg(recs.map(r=>r[D2])),
    d3:avg(recs.map(r=>r[D3])),cf:avg(recs.map(r=>r[CF])),cp:avg(recs.map(r=>r[CP])),
    md,con_f,pct_md:con_f?+(md/con_f*100).toFixed(1):0};
}
function byMes(recs){return MESES.map((m,mi)=>{const r=recs.filter(x=>x[MI]===mi);const a=agg(r);a.lbl=MES_LABEL[m].split(' ')[0];return a;});}
function byCli(recs){
  const map={};
  recs.forEach(r=>{const c=r[CI];if(!map[c])map[c]={c,recs:[]};map[c].recs.push(r);});
  return Object.values(map).map(d=>{
    const a=agg(d.recs);a.name=CLIENTES[d.c];a.c=d.c;
    a.pct_int=a.f>0?+(a.int/a.f*100).toFixed(1):0;
    const oc={},fc={};
    d.recs.forEach(r=>{oc[r[OI]]=(oc[r[OI]]||0)+1;fc[r[FLI]]=(fc[r[FLI]]||0)+1;});
    a.dom_op=TIPO_OPS[+Object.entries(oc).sort((a,b)=>b[1]-a[1])[0][0]];
    a.dom_fl=TIPO_FLS[+Object.entries(fc).sort((a,b)=>b[1]-a[1])[0][0]];
    return a;
  });
}
function byRuta(recs){return[0,1,2,3].map(ri=>{const r=recs.filter(x=>x[RI]===ri);const a=agg(r);a.ri=ri;return a;});}
function byOp(recs){return TIPO_OPS.map((o,oi)=>{const r=recs.filter(x=>x[OI]===oi);const a=agg(r);a.oi=oi;a.name=o;return a;});}
function byFl(recs){return TIPO_FLS.map((f,fi)=>{const r=recs.filter(x=>x[FLI]===fi);const a=agg(r);a.fi=fi;a.name=f;return a;});}

// ══ CHARTS ══
function drawSVG(id,data,series,H=130){
  const svg=document.getElementById(id);if(!svg)return;
  const W=600,PL=22,PR=8,PT=8,PB=18;
  const all=series.flatMap(s=>data.map(d=>d[s.k]??null)).filter(v=>v!=null&&!isNaN(v)&&isFinite(v));
  if(!all.length){svg.innerHTML='';return;}
  const mn=0,mx=Math.max(...all)*1.07||1;
  const n=data.length;
  const xs=i=>n<2?W/2:PL+i*((W-PL-PR)/(n-1));
  const ys=v=>PT+(1-(v-mn)/(mx-mn))*(H-PT-PB);
  let h='';
  for(let i=0;i<=3;i++)h+=`<line x1="${PL}" y1="${PT+i/3*(H-PT-PB)}" x2="${W-PR}" y2="${PT+i/3*(H-PT-PB)}" stroke="#152238" stroke-width="1"/>`;
  data.forEach((d,i)=>{if(d.lbl)h+=`<text x="${xs(i)}" y="${H-3}" text-anchor="middle" class="tick">${d.lbl}</text>`;});
  series.forEach(s=>{
    const pts=data.map((d,i)=>d[s.k]!=null?`${xs(i)},${ys(d[s.k])}`:null).filter(Boolean).join(' ');
    if(pts&&n>1)h+=`<polyline points="${pts}" fill="none" stroke="${s.c}" stroke-width="2" stroke-linejoin="round"/>`;
    data.forEach((d,i)=>{if(d[s.k]==null)return;h+=`<circle cx="${xs(i)}" cy="${ys(d[s.k])}" r="2.5" fill="${s.c}"/>`;});
  });
  svg.innerHTML=h;
}
function drawBars(id,items,maxN=15){
  const el=document.getElementById(id);if(!el)return;
  const top=[...items].filter(x=>x.val>0).sort((a,b)=>b.val-a.val).slice(0,maxN);
  const mx=top[0]?.val||1;
  el.innerHTML=top.map(it=>`<div class="br"><div class="bn" title="${it.name}">${it.name}</div><div class="bt"><div class="bf" style="width:${(it.val/mx*100).toFixed(1)}%;background:${it.col}"></div></div><div class="bv" style="color:${it.col}">${it.disp||fm$(it.val)}</div></div>`).join('');
}
function drawDist(id,bins,cols){
  const el=document.getElementById(id);if(!el)return;
  const mx=Math.max(...bins.map(b=>b.v))||1;
  el.innerHTML=bins.map((b,i)=>`<div class="drow"><div class="dlbl">${b.l}</div><div class="dtr"><div class="dfl" style="width:${(b.v/mx*100).toFixed(1)}%;background:${cols[i]}">${fn(b.v)}</div></div></div>`).join('');
}
function updateBanner(a){
  const s=v=>v!=null?v.toFixed(1):'–';
  const pu='<span class="pu">d</span>';
  document.getElementById('pb1').innerHTML=s(a.d1)+pu;
  document.getElementById('pb2').innerHTML=s(a.d2)+pu;
  document.getElementById('pb3').innerHTML=s(a.d3)+pu;
  document.getElementById('pb-cf').innerHTML=s(a.cf)+pu;
  document.getElementById('pb-cp').innerHTML=s(a.cp)+pu;
  document.getElementById('pb-md').innerHTML=a.pct_md+'<span class="pu">%</span>';
  document.getElementById('pb-mds').textContent=a.md+' / '+a.con_f;
  document.getElementById('h-v').textContent=fn(a.v);
  document.getElementById('h-f').textContent=fm$(a.f);
  document.getElementById('h-i').textContent=fm$(a.int);
  document.getElementById('h-md').textContent=a.pct_md+'%';
  document.getElementById('h-cp').textContent=s(a.cp)+' d';
}

// ══ TABS ══
function go(n){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelector(`[onclick="go('${n}')"]`).classList.add('active');
  document.getElementById('tab-'+n).classList.add('active');
  render();
}

// ══ RENDER DISPATCH ══
let fSF='f',fSD=-1;
function sF(k){const m={'n':'name','v':'v','f':'f','i':'int','m':'pct_int','p':'pag'};if(fSF===m[k])fSD*=-1;else{fSF=m[k];fSD=-1;}render();}
function render(){
  const R=rows();const A=agg(R);updateBanner(A);
  const tab=document.querySelector('.tab.active')?.getAttribute('onclick')?.match(/'(\w+)'/)?.[1]||'res';
  if(tab==='res')  renderRes(R,A);
  if(tab==='pipe') renderPipe(R,A);
  if(tab==='fact') renderFact(R,A);
  if(tab==='cli')  renderCli(R,A);
  if(tab==='ruta') renderRuta(R,A);
  if(tab==='op')   renderOp(R,A);
  if(tab==='nov')  renderNov();
}

// ════ RESUMEN ════
function renderRes(R,A){
  const pct=A.f>0?(A.int/A.f*100).toFixed(1):0;
  document.getElementById('kpi-res').innerHTML=`
    <div class="km k1"><div class="kl">Facturación</div><div class="kv">${fm$(A.f)}</div><div class="ks">${fn(A.v)} viajes</div></div>
    <div class="km k2"><div class="kl">Intermediación</div><div class="kv">${fm$(A.int)}</div><div class="ks">${pct}% del total</div></div>
    <div class="km k3"><div class="kl">Total C→Factura</div><div class="kv">${fd(A.cf)}</div><div class="ks">Ciclo operativo</div></div>
    <div class="km k4"><div class="kl">Total C→Pago</div><div class="kv">${fd(A.cp)}</div><div class="ks">Ciclo financiero</div></div>
    <div class="km k5"><div class="kl">⚡ Mismo día</div><div class="kv">${A.pct_md}%</div><div class="ks">${A.md} remesas</div></div>
    <div class="km" style="border-top:2px solid var(--mut)"><div class="kl">Clientes activos</div><div class="kv" style="color:var(--txt)">${new Set(R.map(r=>r[CI])).size}</div><div class="ks">período</div></div>`;
  const md=byMes(R);
  drawSVG('svg-r-fact',md,[{k:'f',c:'var(--a1)'},{k:'int',c:'var(--a4)'},{k:'pag',c:'var(--a5)'}]);
  const opD=byOp(R);const totV=A.v||1;
  ['r-op-dist','r-fl-dist'].forEach((id,si)=>{
    const data=si===0?opD:byFl(R);const cols=si===0?OC:FC_;
    const names=si===0?TIPO_OPS:TIPO_FLS;
    document.getElementById(id).innerHTML=data.map((d,i)=>{const p=(d.v/totV*100).toFixed(0);return`<div style="margin-bottom:9px;"><div style="display:flex;justify-content:space-between;font-size:10px;margin-bottom:3px;"><span style="color:${cols[i]}">${names[i]}</span><span style="color:var(--mut)">${fn(d.v)} · ${p}% · ${fm$(d.f)}</span></div><div style="height:6px;background:var(--bdr);border-radius:3px;overflow:hidden;"><div style="width:${p}%;height:100%;background:${cols[i]};border-radius:3px;"></div></div></div>`;}).join('');
  });
  const cli=byCli(R).sort((a,b)=>b.f-a.f);
  drawBars('r-bar-f',cli.map(d=>({name:d.name,val:d.f,col:'var(--a1)'})));
  drawBars('r-bar-i',cli.sort((a,b)=>b.int-a.int).map(d=>({name:d.name,val:d.int,col:'var(--a4)'})));
}

// ════ PIPELINE ════
function renderPipe(R,A){
  document.getElementById('kpi-pipe').innerHTML=`
    <div class="km k1"><div class="kl">⌀ Cargue→Cumplido</div><div class="kv">${fd(A.d1)}</div><div class="ks">Paso 1</div></div>
    <div class="km k2"><div class="kl">⌀ Cumplido→Factura</div><div class="kv">${fd(A.d2)}</div><div class="ks">Paso 2</div></div>
